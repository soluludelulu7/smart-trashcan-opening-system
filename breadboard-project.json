  "fileGroups": {
    "group-arduino-uno": [
      {
        "name": "sketch.ino",
        "content": "#include <Servo.h>\nServo s;\nenum {Closed, Open} state = Closed;\n\nvoid setup() {\n    s.attach(9);\n}\n\nvoid loop() {\n    bool button = !digitalRead(2);\n    bool vibration = !digitalRead(3);\n    bool angle = !analogRead(A0);\n\n    switch (state) {\n        case Closed:\n            s.write(0);\n            digitalWrite(5, HIGH);\n            if (button || vibration || angle) {\n                state = Open;\n            }\n        \n        case Open:\n            s.write(0);\n            digitalWrite(6, HIGH);\n            if (button || vibration || angle) {\n                state = Closed;\n            }\n    }\n}"
      }
    ]
  },
